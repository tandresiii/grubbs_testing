# Copy this file to .env for local dev. On Railway, set these as
# service variables in the dashboard instead.

# Postgres connection string. Railway's Postgres add-on provides this
# automatically via the ${{ Postgres.DATABASE_URL }} reference.
DATABASE_URL=postgres://user:password@localhost:5432/infiniti_assessment

# Used to sign session cookies. Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Shared code that reps must enter to start the test. Give this out verbally
# per session or rotate periodically.
TEST_ACCESS_CODE=E360-2026

# Admin dashboard credentials.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-too

# Set to 'production' on Railway; leave unset locally.
# NODE_ENV=production
